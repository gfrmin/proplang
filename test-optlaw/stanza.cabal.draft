-- Insert into proplang.cabal after the last test-suite stanza:

test-suite optlaw
    import:           warnings
    type:             exitcode-stdio-1.0
    main-is:          OptLaw.hs
    hs-source-dirs:   test-optlaw
    build-depends:    base
                    , proplang
                    , tasty
                    , tasty-hunit
    default-language: GHC2021

-- The frozen gate 5 (`cabal test all`) absorbs this suite with no edit to
-- any frozen audit script -- CLAUDE.md's increment protocol, clause 1.
--
-- The `warnings` import is load-bearing and NOT a formality: the oracle-phase
-- runner must be bit-faithful to the future gate conditions -- the stanza's
-- exact compiler flags and warning set. "A red run under weaker flags proves
-- nothing" (the ExpFam re-open, 4c7b49d).
