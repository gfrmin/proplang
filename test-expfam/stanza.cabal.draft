-- test-expfam/stanza.cabal.draft — the expfam increment's test-suite
-- stanza (EXPFAM_PLAN E10). proplang.cabal is frozen (manifest entry
-- since b1c8e00), so the builder cannot apply this; the AUTHOR pastes
-- the stanza below into proplang.cabal inside the Task 2 freeze
-- commit, alongside the author pack amendments and the re-signing
-- (author pack §5). Until then the oracle runs red via the E10
-- out-of-cabal runner.

test-suite expfam
    import:           warnings
    type:             exitcode-stdio-1.0
    main-is:          ExpFam.hs
    hs-source-dirs:   test-expfam
    build-depends:    base
                    , proplang
                    , tasty
                    , tasty-hunit
                    , tasty-quickcheck
                    , QuickCheck
                    , process
    default-language: GHC2021
